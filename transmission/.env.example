# Timezone
TZ=America/Toronto

# Mullvad WireGuard credentials
# Get these from https://mullvad.net/en/account/wireguard-config
MULLVAD_WIREGUARD_PRIVATE_KEY=your-wireguard-private-key
MULLVAD_WIREGUARD_ADDRESS=your-wireguard-address/32

# Optional: preferred Mullvad server city (e.g., "new york ny", "zurich")
MULLVAD_SERVER_CITY=
